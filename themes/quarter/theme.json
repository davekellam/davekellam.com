{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"link": true,
			"palette": [
				{
					"name": "Background",
					"slug": "background",
					"color": "#ffffff"
				},
				{
					"name": "Text",
					"slug": "text",
					"color": "#404040"
				},
				{
					"name": "Link",
					"slug": "link",
					"color": "#4169e1"
				},
				{
					"name": "Link Hover",
					"slug": "link-hover",
					"color": "#191970"
				},
				{
					"name": "Border",
					"slug": "border",
					"color": "#cccccc"
				},
				{
					"name": "Subtle",
					"slug": "subtle",
					"color": "#eeeeee"
				},
				{
					"name": "Muted",
					"slug": "muted",
					"color": "#999999"
				}
			]
		},
		"layout": {
			"contentSize": "42rem",
			"wideSize": "64rem"
		},
		"spacing": {
			"spacingSizes": [
				{ "name": "1", "slug": "1", "size": "0.25rem" },
				{ "name": "2", "slug": "2", "size": "0.5rem" },
				{ "name": "3", "slug": "3", "size": "1rem" },
				{ "name": "4", "slug": "4", "size": "1.5rem" },
				{ "name": "5", "slug": "5", "size": "2rem" },
				{ "name": "6", "slug": "6", "size": "3rem" },
				{ "name": "7", "slug": "7", "size": "4.5rem" }
			],
			"units": [ "rem", "em", "px", "%" ]
		},
		"typography": {
			"customFontSize": false,
			"lineHeight": true,
			"fontFamilies": [
				{
					"name": "Monospace",
					"slug": "monospace",
					"fontFamily": "\"SF Mono\", ui-monospace, \"Cascadia Code\", \"Source Code Pro\", Menlo, Consolas, \"DejaVu Sans Mono\", monospace"
				}
			],
			"fontSizes": [
				{ "name": "Small",    "slug": "small",    "size": "0.8rem" },
				{ "name": "Base",     "slug": "base",     "size": "1rem" },
				{ "name": "Medium",   "slug": "medium",   "size": "1.125rem" },
				{ "name": "Large",    "slug": "large",    "size": "1.5rem" },
				{ "name": "X-Large",  "slug": "x-large",  "size": "2rem" },
				{ "name": "XX-Large", "slug": "xx-large", "size": "2.5rem" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--text)"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--4)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--monospace)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.8"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--link)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--link-hover)"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--link)",
						"offset": "2px",
						"style": "dotted",
						"width": "1px"
					}
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.3"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.4"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.5"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--base)",
					"lineHeight": "1.5"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "1.5"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
